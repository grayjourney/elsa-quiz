# Copy to .env and adjust. All values have sensible defaults.
# docker compose auto-loads .env; these set the HOST-side ports, so override any
# that clash with something already running on your machine (avoids the
# "port is already allocated" error). Container-internal ports never change.

# Quiz server — host port (container always listens on 8080).
PORT=8080

# Points awarded per correct answer.
BASE_POINTS=10

# Observability UIs — host ports (override if 9090 / 3000 are taken locally).
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
