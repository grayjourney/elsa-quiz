          "name": "Get session",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/sessions/{{quizId}}", "host": ["{{baseUrl}}"], "path": ["api", "sessions", "{{quizId}}"] },
