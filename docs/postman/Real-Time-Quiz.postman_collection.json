          },
          "response": [
            {
              "name": "404 Not Found",
              "originalRequest": { "method": "GET", "header": [], "url": { "raw": "{{baseUrl}}/api/sessions/QUIZ-999", "host": ["{{baseUrl}}"], "path": ["api", "sessions", "QUIZ-999"] } },
              "status": "Not Found",
