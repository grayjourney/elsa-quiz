              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "_postman_previewlanguage": "json",
              "body": "{\n  \"quizId\": \"QUIZ-7KQH4ZB2N9XA\",\n  \"status\": \"active\",\n  \"endPolicy\": \"manual\",\n  \"participantCount\": 3,\n  \"currentQuestion\": { \"id\": \"Q1\", \"order\": 1 }\n}"
            }
          ]
        },
        {
          "name": "Get session (unknown) → 404 session_not_found",
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('404 Not Found', () => pm.response.to.have.status(404));", "pm.test('code session_not_found', () => pm.expect(pm.response.json().code).to.eql('session_not_found'));" ] } } ],
          "request": {
