    {
      "name": "Session Management",
      "item": [
        {
          "name": "Create session (manual policy)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201 Created', () => pm.response.to.have.status(201));",
                  "const b = pm.response.json();",
                  "pm.test('returns a quiz ID', () => pm.expect(b.quizId).to.be.a('string').and.not.empty);",
                  "pm.test('status is waiting', () => pm.expect(b.status).to.eql('waiting'));",
                  "pm.collectionVariables.set('quizId', b.quizId);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/sessions", "host": ["{{baseUrl}}"], "path": ["api", "sessions"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"endPolicy\": \"manual\",\n  \"timeLimitSeconds\": 0,\n  \"questions\": [\n    {\n      \"id\": \"Q1\",\n      \"text\": \"What is the past tense of 'go'?\",\n      \"options\": [\"goed\", \"went\", \"gone\", \"going\"],\n      \"correctAnswer\": \"went\",\n      \"order\": 1\n    },\n    {\n      \"id\": \"Q2\",\n      \"text\": \"What is the plural of 'mouse'?\",\n      \"options\": [\"mouses\", \"mice\", \"mouse\", \"meese\"],\n      \"correctAnswer\": \"mice\",\n      \"order\": 2\n    }\n  ]\n}"
            },
            "description": "Covers: *Session Lifecycle → Creating a session with the manual end policy* and *Quiz Session Management → Creating a new quiz session*.\n\nThe `quizId` returned is saved to a collection variable and reused by later requests."
          },
          "response": [
            {
              "name": "201 Created",
              "originalRequest": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{baseUrl}}/api/sessions", "host": ["{{baseUrl}}"], "path": ["api", "sessions"] }, "body": { "mode": "raw", "raw": "{ \"endPolicy\": \"manual\", \"questions\": [] }" } },
              "status": "Created",
              "code": 201,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "_postman_previewlanguage": "json",
              "body": "{\n  \"quizId\": \"QUIZ-7KQH4ZB2N9XA\",\n  \"status\": \"waiting\",\n  \"endPolicy\": \"manual\",\n  \"timeLimitSeconds\": 0,\n  \"questionCount\": 2\n}"
            }
          ]
        },
        {
          "name": "Create session (timed policy, 30s)",
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('201 Created', () => pm.response.to.have.status(201));", "const b = pm.response.json();", "pm.test('endPolicy timed', () => pm.expect(b.endPolicy).to.eql('timed'));", "pm.test('30s limit', () => pm.expect(b.timeLimitSeconds).to.eql(30));" ] } } ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/sessions", "host": ["{{baseUrl}}"], "path": ["api", "sessions"] },
            "body": { "mode": "raw", "raw": "{\n  \"endPolicy\": \"timed\",\n  \"timeLimitSeconds\": 30,\n  \"questions\": [\n    {\n      \"id\": \"Q1\",\n      \"text\": \"What is the past tense of 'go'?\",\n      \"options\": [\"goed\", \"went\", \"gone\", \"going\"],\n      \"correctAnswer\": \"went\",\n      \"order\": 1\n    }\n  ]\n}" },
            "description": "Covers: *Session Lifecycle → Creating a session with the timed end policy*."
          },
          "response": [
            {
              "name": "201 Created",
              "originalRequest": { "method": "POST", "header": [], "url": { "raw": "{{baseUrl}}/api/sessions", "host": ["{{baseUrl}}"], "path": ["api", "sessions"] } },
              "status": "Created",
              "code": 201,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "_postman_previewlanguage": "json",
              "body": "{\n  \"quizId\": \"QUIZ-3MN8WQ5RT2YC\",\n  \"status\": \"waiting\",\n  \"endPolicy\": \"timed\",\n  \"timeLimitSeconds\": 30,\n  \"questionCount\": 1\n}"
            }
          ]
        },
        {
          "name": "Create session (timed, 0s) → 400 invalid_time_limit",
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('400 Bad Request', () => pm.response.to.have.status(400));", "pm.test('code invalid_time_limit', () => pm.expect(pm.response.json().code).to.eql('invalid_time_limit'));" ] } } ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/sessions", "host": ["{{baseUrl}}"], "path": ["api", "sessions"] },
            "body": { "mode": "raw", "raw": "{\n  \"endPolicy\": \"timed\",\n  \"timeLimitSeconds\": 0,\n  \"questions\": [\n    { \"id\": \"Q1\", \"text\": \"x\", \"options\": [\"a\", \"b\"], \"correctAnswer\": \"a\", \"order\": 1 }\n  ]\n}" },
            "description": "Covers: *Session Lifecycle → Rejecting a timed session with a non-positive time limit*."
          },
          "response": [
            {
              "name": "400 Bad Request",
              "originalRequest": { "method": "POST", "header": [], "url": { "raw": "{{baseUrl}}/api/sessions", "host": ["{{baseUrl}}"], "path": ["api", "sessions"] } },
              "status": "Bad Request",
              "code": 400,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "_postman_previewlanguage": "json",
              "body": "{\n  \"code\": \"invalid_time_limit\",\n  \"message\": \"Time limit must be greater than zero\"\n}"
            }
          ]
        },
