          "name": "Prometheus metrics",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/metrics", "host": ["{{baseUrl}}"], "path": ["metrics"] },
            "description": "Prometheus exposition format. Covers NFR-5.3 (metrics)."
          },
          "response": [
            {
              "name": "200 OK",
              "originalRequest": { "method": "GET", "header": [], "url": { "raw": "{{baseUrl}}/metrics", "host": ["{{baseUrl}}"], "path": ["metrics"] } },
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "text/plain; version=0.0.4" }],
              "_postman_previewlanguage": "text",
              "body": "# HELP quiz_active_sessions Number of active quiz sessions\n# TYPE quiz_active_sessions gauge\nquiz_active_sessions 1\n# HELP quiz_connected_users Connected users\n# TYPE quiz_connected_users gauge\nquiz_connected_users 5\n# HELP quiz_message_latency_ms Score-update broadcast latency\n# TYPE quiz_message_latency_ms histogram\nquiz_message_latency_ms_bucket{le=\"500\"} 4200"
            }
